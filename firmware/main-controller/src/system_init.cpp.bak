#include <Arduino.h>
#include <Wire.h>

#define AI_SDA_PIN 4
#define AI_SCL_PIN 13

void scanI2C() {
    Serial.println();
    Serial.println("=================================");
    Serial.println("Scanning AI I2C Bus...");
    Serial.println("=================================");

    uint8_t found = 0;

    for (uint8_t address = 1; address < 127; address++) {

        Wire.beginTransmission(address);
        uint8_t error = Wire.endTransmission();

        if (error == 0) {
            Serial.print("[FOUND] Device at 0x");

            if (address < 16) {
                Serial.print("0");
            }

            Serial.println(address, HEX);
            found++;
        }
    }

    if (found == 0) {
        Serial.println("[SCAN] No devices found");
    }

    Serial.println("---------------------------------");
}

void setup() {
    Serial.begin(115200);
    delay(1000);

    Serial.println();
    Serial.println("ESP32 AI Bus Scanner");

    // Dedicated AI I2C bus
    Wire.begin(AI_SDA_PIN, AI_SCL_PIN, 100000);

    scanI2C();
}

void loop() {
    scanI2C();
    delay(5000);
}